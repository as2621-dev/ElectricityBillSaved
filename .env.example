# Copy to .env and fill in real values. Never commit .env.
# .env is gitignored; .env.example is the onboarding contract.

# ─── LLM providers ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ─── Backend (pick one) ───────────────────────────────────
# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Payments ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Background jobs ──────────────────────────────────────
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Aprilaire thermostats — local LAN path (prototype only) ───
# Requires Connection Type = Automation (disables the phone app). Not scalable.
# Port is 8000 for S86WMUPR / 8800-series (7001 is only the pyaprilaire mock).
APRILAIRE_2F_HOST=
APRILAIRE_1F_HOST=
APRILAIRE_PORT=8000

# ─── Aprilaire cloud path (scalable, keeps the phone app) ───
# Your AprilAire "Healthy Air" app login. Never commit real values.
# Used to reach aprilaire.io (AWS Cognito). Store refresh tokens, not passwords,
# in any multi-user/production design — this is for local probing only.
APRILAIRE_CLOUD_EMAIL=
APRILAIRE_CLOUD_PASSWORD=
# Account-specific IDs (not secret). Discover them by running cloud_probe.py.
APRILAIRE_LOCATION_ID=
APRILAIRE_2F_DEVICE_ID=
APRILAIRE_1F_DEVICE_ID=

# ─── Smart Meter Texas — daily CSV via IMAP (M1 ingest) ───
# SMT emails the 15-min interval report (CSV attachment) to your account-profile
# inbox. We read it over IMAP. For Gmail you MUST use a 16-char App Password
# (Google Account → Security → 2-Step Verification → App passwords), NOT your
# login password and NOT OAuth. Never commit the real value.
SMT_IMAP_HOST=imap.gmail.com
SMT_IMAP_PORT=993
SMT_IMAP_USERNAME=ashesh.srivastava1234@gmail.com
SMT_IMAP_APP_PASSWORD=
# Folder/label to search, and a substring of the SMT sender to match.
SMT_IMAP_MAILBOX=INBOX
SMT_EMAIL_FROM_FILTER=smartmetertexas.com
# Where fetched CSVs land (gitignored; personal usage data).
SMT_DEST_DIR=data/smt
# Your meter identifiers (read from the CSV after the first fetch; optional for now).
SMT_ESI_ID=
SMT_METER_NUMBER=

# ─── Weather projection — Open-Meteo (free, no API key) ───
# Projects daily min/max temp + rainfall over a billing cycle: live ~16-day
# forecast + multi-year climatology backfill. ZIP -> coords via zippopotam.us.
# No key/signup for any of these. WEATHER_ZIP is the default for show_weather.py.
WEATHER_ZIP=
